# mindOS AI service — environment variables (F0)
# Copy to .env and adjust for local development.

PORT=8000

# Data stores (shared with the API, see infra/docker-compose.yml)
DATABASE_URL="postgresql://mindos:mindos@localhost:5432/mindos"
REDIS_URL="redis://localhost:6379"

# LLM provider (provider-agnostic layer, ADR-09). Concrete keys added in F2.
LLM_PROVIDER="none"
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""
