# mindOS AI service — environment variables
# Copy to .env and adjust for local development.

PORT=8000

# Data stores (shared with the API, see infra/docker-compose.yml)
DATABASE_URL="postgresql://mindos:mindos@localhost:5432/mindos"
REDIS_URL="redis://localhost:6379"

# LLM provider (provider-agnostic layer, ADR-09 / ADR-012 D4).
# 'fake'   -> deterministic, offline, zero cost (default; used by the eval PoC)
# 'openai' -> real OpenAI provider (requires OPENAI_API_KEY below)
# 'groq'   -> free, OpenAI-compatible provider (requires GROQ_API_KEY; no card)
# 'gemini' -> free, OpenAI-compatible provider (requires GEMINI_API_KEY; no card)
LLM_PROVIDER="fake"

# OpenAI provider (only needed when LLM_PROVIDER="openai")
# OPENAI_API_KEY=""
# gpt-5.4-mini = cheap tier for tuning (~$0.08 / full eval run).
# For the FINAL run switch to the flagship: OPENAI_MODEL="gpt-5.5"
# (~$0.50 / full eval run, best quality / least hallucination). No code change.
OPENAI_MODEL="gpt-5.4-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Groq provider (only needed when LLM_PROVIDER="groq"). Free, no credit card:
# get a key at https://console.groq.com -> API Keys. Groq is OpenAI-compatible,
# so it reuses the OPENAI_MAX_RETRIES / OPENAI_BACKOFF_BASE_S settings below.
# GROQ_API_KEY=""
# If Groq deprecates this model, just change it here (see console.groq.com/docs/models).
GROQ_MODEL="llama-3.3-70b-versatile"

# Gemini provider (only needed when LLM_PROVIDER="gemini"). Free, no credit card:
# get a key at https://aistudio.google.com/app/apikey. Gemini exposes an
# OpenAI-compatible endpoint, so it reuses the OPENAI_MAX_RETRIES /
# OPENAI_BACKOFF_BASE_S settings below; its free tier is more generous than Groq.
# GEMINI_API_KEY=""
# Override the model without code changes (see ai.google.dev/gemini-api/docs/models).
# Default gemini-2.0-flash is confirmed available/working on the key. Its free
# tier has a low daily request cap (~200/day) that resets daily; enabling paid
# billing lifts it. (gemini-1.5-flash was retired by Google for new projects and
# now fails fast with an APIError, so it is not a usable default.)
GEMINI_MODEL="gemini-2.0-flash"

# Resilience against rate limits (429) and transient errors. The provider
# retries API calls with exponential backoff + jitter (honouring Retry-After).
# Shared by the OpenAI and Groq providers (same underlying SDK).
OPENAI_MAX_RETRIES=5
OPENAI_BACKOFF_BASE_S=2.0

# Evaluation gate thresholds (design §13.2) — PROVISIONAL, pending product sign-off.
EVAL_F1_ENTITIES_MIN=0.80
EVAL_TASK_PRECISION_MIN=0.85
EVAL_HALLUCINATION_MAX=0.05
EVAL_COST_PER_CAPTURE_MAX_USD=0.01

# Pause (seconds) between eval cases so a real-provider run stays under a fresh
# account's requests-per-minute limit. Keep 0 for the offline FakeProvider.
EVAL_REQUEST_DELAY_S=0.0
