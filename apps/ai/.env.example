# mindOS AI service — environment variables
# Copy to .env and adjust for local development.

PORT=8000

# Data stores (shared with the API, see infra/docker-compose.yml)
DATABASE_URL="postgresql://mindos:mindos@localhost:5432/mindos"
REDIS_URL="redis://localhost:6379"

# LLM provider (provider-agnostic layer, ADR-09 / ADR-012 D4).
# 'fake'   -> deterministic, offline, zero cost (default; used by the eval PoC)
# 'openai' -> real OpenAI provider (requires OPENAI_API_KEY below)
LLM_PROVIDER="fake"

# OpenAI provider (only needed when LLM_PROVIDER="openai")
# OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# Resilience against rate limits (429) and transient errors. The provider
# retries API calls with exponential backoff + jitter (honouring Retry-After).
OPENAI_MAX_RETRIES=5
OPENAI_BACKOFF_BASE_S=2.0

# Evaluation gate thresholds (design §13.2) — PROVISIONAL, pending product sign-off.
EVAL_F1_ENTITIES_MIN=0.80
EVAL_TASK_PRECISION_MIN=0.85
EVAL_HALLUCINATION_MAX=0.05
EVAL_COST_PER_CAPTURE_MAX_USD=0.01

# Pause (seconds) between eval cases so a real-provider run stays under a fresh
# account's requests-per-minute limit. Keep 0 for the offline FakeProvider.
EVAL_REQUEST_DELAY_S=0.0
