# mindOS API — environment variables
# Copy to .env and adjust for local development.

PORT=3000

# PostgreSQL (see infra/docker-compose.yml)
#
# RLS / fail-closed isolation (design.md §6):
#   The application MUST connect as a NON-OWNER, NON-SUPERUSER role
#   (e.g. `mindos_app`). PostgreSQL only enforces `FORCE ROW LEVEL SECURITY`
#   for roles that are neither the table owner nor a superuser, so connecting as
#   the owner/superuser would silently bypass the isolation policies.
#
#   `DATABASE_URL` is the runtime connection used by the app => must be the
#   non-owner app role. See the raw RLS migration for the GRANTs that role needs.
DATABASE_URL="postgresql://mindos_app:mindos_app@localhost:5432/mindos?schema=public"

# Migrations / schema ownership. Prisma migrations (DDL: CREATE TABLE, ENABLE
# RLS, CREATE POLICY, GRANT ...) must run as the table OWNER / migration role,
# NOT as the non-owner app role above. Point your migration command at this URL
# (e.g. `DATABASE_URL=$MIGRATION_DATABASE_URL npx prisma migrate deploy`).
MIGRATION_DATABASE_URL="postgresql://mindos:mindos@localhost:5432/mindos?schema=public"

# Redis (queue / cache / pubsub)
REDIS_URL="redis://localhost:6379"

# Internal AI service (Python/FastAPI)
AI_SERVICE_URL="http://localhost:8000"

# JWT auth (built in-house — see #07). Use a strong secret in real environments.
JWT_SECRET="change-me-in-non-local-environments"
JWT_ACCESS_TTL="3600"        # access token lifetime, seconds (1 hour)
JWT_REFRESH_TTL="1209600"    # refresh token lifetime, seconds (14 days)
