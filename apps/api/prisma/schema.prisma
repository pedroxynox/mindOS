// mindOS — Prisma schema.
//
// The full knowledge-graph schema (nodes / edges) is defined in
// docs/03-data/data-architecture-and-domain-model.md and grows with each phase.
// F1a adds the identity model needed for authentication.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A registered user. Passwords are stored only as a strong hash (#07).
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("users")
}
