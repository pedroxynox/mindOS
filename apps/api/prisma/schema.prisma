// mindOS — Prisma schema.
//
// The full knowledge-graph schema (nodes / edges) is defined in
// docs/03-data/data-architecture-and-domain-model.md and grows with each phase.
// F1a added the identity model needed for authentication.
// F1 (capture-engine) adds the property-graph tables (nodes / edges) plus the
// idempotency ledger backing POST /v1/captures. See design.md §5.
//
// ARCHITECTURE DECISION (CPTO): native UUID everywhere. Every primary key and
// foreign key uses `@db.Uuid` so that graph foreign keys and the RLS policy
// (`= current_setting('app.current_user_id', true)::uuid`) work natively without
// per-row text->uuid casts. At the application layer these ids remain strings;
// only the Postgres column type changes.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A registered user. Passwords are stored only as a strong hash (#07).
model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Inverse relations for the F1 property graph.
  nodes           Node[]
  edges           Edge[]
  idempotencyKeys IdempotencyKey[]
  refreshTokens   RefreshToken[]
  llmUsage        LlmUsage[]

  @@map("users")
}

/// Rotating refresh-token ledger — single-use rotation + reuse detection (R-002).
///
/// Only the HASH of the opaque refresh token is persisted, NEVER the token
/// itself: a database leak must not hand an attacker usable tokens. Tokens are
/// grouped into a `family` (one login session). On a normal refresh the used
/// token is revoked and `replacedById` points at its successor. If an already
/// revoked/used token is presented again (token theft signal) the whole family
/// is revoked at once, killing both the legitimate and the stolen chain.
///
/// SECURITY BOUNDARY (no RLS on this table — documented decision): authentication
/// is the identity frontier and runs BEFORE any user context exists. The RLS
/// policies on the graph tables rely on `app.current_user_id`, which is derived
/// from a validated access token; refresh/login/logout operate precisely to
/// establish that identity and therefore cannot depend on it. Isolation here is
/// enforced by the opaque, high-entropy token + its stored hash and explicit
/// `user_id` scoping in every query, not by row-level security.
model RefreshToken {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  tokenHash    String   @unique @map("token_hash") // sha256 of the opaque token — never the token itself
  family       String   @db.Uuid // session/family id; reuse of any member revokes the whole family
  expiresAt    DateTime @map("expires_at") @db.Timestamptz(6)
  revoked      Boolean  @default(false)
  replacedById String?  @map("replaced_by_id") @db.Uuid // successor token after a rotation
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_refresh_tokens_user")
  @@index([family], name: "idx_refresh_tokens_family")
  @@map("refresh_tokens")
}

enum NodeType {
  capture
  note
  task
  person
  project
  event
  decision
  topic

  @@map("node_type")
}

/// Status of the understanding pipeline over a capture (ADR-02 / #03 §5).
/// F1 only ever writes `raw`. F2 transitions raw -> processing -> processed | failed.
enum CaptureStatus {
  raw
  processing
  processed
  failed

  @@map("capture_status")
}

enum CaptureModality {
  text
  voice

  @@map("capture_modality")
}

enum NodeOrigin {
  manual_text
  voice
  calendar_sync
  ai

  @@map("node_origin")
}

/// Property-graph node. All node types share this table, discriminated by
/// `type`. Type-specific fields live in `attributes` (JSONB).
model Node {
  id         String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String        @map("user_id") @db.Uuid
  type       NodeType
  title      String?
  body       String? // raw text / transcription content
  attributes Json          @default("{}") // e.g. { "audio_ref": "...", "modality": "voice" }
  status     CaptureStatus @default(raw) // relevant for type=capture
  origin     NodeOrigin
  confidence Float? // null for captures (not AI-derived)
  // Semantic embedding (F2). Prisma cannot natively type pgvector, so the column
  // type is declared via `Unsupported(...)` and populated with raw SQL by the
  // Python worker; the HNSW index lives in the F2 raw-SQL migration. Kept in the
  // schema (rather than fully omitted) so `prisma migrate diff` sees no drift.
  embedding      Unsupported("vector(1536)")? // dimension = Settings.embedding_dim
  embeddingModel String?                       @map("embedding_model")
  occurredAt DateTime?     @map("occurred_at") @db.Timestamptz(6)
  createdAt  DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt  DateTime?     @map("deleted_at") @db.Timestamptz(6)

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  outgoingEdges   Edge[]           @relation("SourceNode")
  incomingEdges   Edge[]           @relation("TargetNode")
  idempotencyKeys IdempotencyKey[]
  llmUsage        LlmUsage[]

  @@index([userId, type], name: "idx_nodes_user_type")
  @@index([userId, status])
  @@map("nodes")
}

/// Typed, directional edge (adjacency list). F1 creates no edges; the model is
/// defined so F2 can use it without a new structural migration.
model Edge {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  type          String // 'derived_from','mentions',...
  sourceNodeId  String    @map("source_node_id") @db.Uuid
  targetNodeId  String    @map("target_node_id") @db.Uuid
  confidence    Float?
  origin        String // 'ai' | 'user' | 'integration'
  userConfirmed Boolean   @default(false) @map("user_confirmed")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz(6)

  sourceNode Node @relation("SourceNode", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode Node @relation("TargetNode", fields: [targetNodeId], references: [id], onDelete: Cascade)
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sourceNodeId], name: "idx_edges_source")
  @@index([userId, targetNodeId], name: "idx_edges_target")
  @@map("edges")
}

/// Idempotency ledger for POST /v1/captures. The key is client-provided
/// (Idempotency-Key); in offline sync it is Drift's client_id.
model IdempotencyKey {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  key         String
  captureId   String   @map("capture_id") @db.Uuid
  requestHash String   @map("request_hash") // payload hash to detect reuse with a different body
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  capture Node @relation(fields: [captureId], references: [id], onDelete: Cascade)
  user    User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key], name: "uq_idempotency_user_key")
  @@map("idempotency_keys")
}

/// Per-user LLM cost ledger (F2, first-class cost metric #02). Every model call
/// (complete / embed / transcribe) made by the understanding worker is recorded
/// here, attributed to the job's user. RLS (fail-closed, same pattern as the
/// graph tables) is added by the F2 raw-SQL migration, not expressible in Prisma.
model LlmUsage {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  captureId    String?  @map("capture_id") @db.Uuid // source capture; kept if the node is deleted
  provider     String // 'openai' | 'groq' | 'gemini' | ...
  model        String
  operation    String // 'complete' | 'embed' | 'transcribe'
  inputTokens  Int      @default(0) @map("input_tokens")
  outputTokens Int      @default(0) @map("output_tokens")
  costUsd      Decimal  @default(0) @map("cost_usd") @db.Decimal(12, 6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  capture Node? @relation(fields: [captureId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt], name: "idx_llm_usage_user")
  @@map("llm_usage")
}
